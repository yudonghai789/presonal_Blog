    "# 5G NR 信号处理：FFT 与加窗实战\n",
    "作为 NR 工程师，我们需要理解 DFT 公式：\n",
    "$$X[k] = \\sum_{n=0}^{N-1} x[n] e^{-j\\frac{2\\pi}{N}kn}$$\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8b17cf24",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import scipy.signal as signal\n",
    "\n",
    "# 构造 16-QAM 信号\n",
    "fs = 30.72e6\n",
    "t = np.arange(256) / fs\n",
    "sig = np.random.choice([-3-3j, -3-1j, 1+1j, 3+3j], 256)\n",
    "# 加窗\n",
    "win = signal.windows.hann(256)\n",
    "sig_win = sig * win\n",
    "\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.subplot(1, 2, 1); plt.plot(win); plt.title(\"Hanning Window\")\n",
    "plt.subplot(1, 2, 2); plt.scatter(sig_win.real, sig_win.imag, s=10); plt.title(\"Windowed Constellation\")\n",
    "plt.show()"
   ]
  }
 ],
